{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/((?!api/).*\\.[a-zA-Z0-9]+)$",
      "dest": "/client/dist/$1"
    },
    {
      "src": "/((?!api/).*)$",
      "dest": "/client/dist/index.html"
    }
  ]
}
